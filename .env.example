# .env.example
# このファイルはGitHubに公開します（実際のキーは書かない）
# cp .env.example .env

EDINETDB_API_KEY=your_edinetdb_api_key_here
JQUANTS_API_KEY=your_jquants_api_key_here

# Render/Supabase 本番用。ローカル Docker では docker-compose.yml の DATABASE_URL が使われます。
# Supabase の接続文字列は sslmode=require を付けてください。
# 例: postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@db:5432/stock_screening
